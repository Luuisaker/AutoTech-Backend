# AutoTech Backend — Environment Variables

# Required:
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autotech
SECRET_KEY=change-this-to-a-random-secret-key

# Server (defaults shown — Render sets PORT automatically)
# HOST=0.0.0.0
# PORT=8000

# File uploads (Render: /opt/render/project/src/uploads)
# UPLOAD_DIR=uploads

# Resend para recuperación de contraseña (opcional — sin esto el forgot-password es no-op)
# RESEND_API_KEY=re_xxxxxxxxxxxx
# Para enviar a cualquier correo, verifica tu dominio en Resend y usa:
# RESEND_FROM=AutoTech <noreply@tudominio.com>
# Con onboarding@resend.dev (default) solo se envía al correo del dueño de la cuenta

# Frontend URL for CORS and email links (set to your Vercel URL in production)
# FRONTEND_URL=http://localhost:5173

# Cron endpoint protection
# CRON_API_KEY=autotech-cron-key-2026

# BCV exchange rate API (default: dolarapi.com)
# BCV_API_URL=https://ve.dolarapi.com/v1/dolares/bcv
