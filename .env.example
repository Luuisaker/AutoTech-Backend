# AutoTech Backend — Environment Variables

DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/autotech
SECRET_KEY=change-this-to-a-random-secret-key

# Optional:
# HOST=127.0.0.1
# PORT=8000
# UPLOAD_DIR=uploads

# SMTP para recuperación de contraseña (opcional — sin esto el forgot-password es no-op)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=tu-correo@gmail.com
# SMTP_PASSWORD=tu-contraseña-de-aplicacion
# SMTP_FROM_EMAIL=tu-correo@gmail.com
# FRONTEND_URL=http://localhost:5173
